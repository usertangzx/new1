[project]
name = "teach-det"
version = "0.1.0a"
authors = [
]
description = "用于教学。"
readme = "README.md"
requires-python = "==3.9.*"
keywords = ["vue", "backend", "mysql", "warning"]
classifiers = [
    "Development Status :: 4 - Beta",
    "Programming Language :: Python :: 3",
    "Operating System :: OS Independent",
]

dependencies = [
    "sqlalchemy",#ORM 框架	数据库对象关系映射，用 Python 类操作数据库表
    "pymysql", #MySQL 驱动	让 Python 连接和操作 MySQL 数据库
    "flask", #轻量级 Web 框架	构建 Web 应用、API 接口、路由处理
    "waitress", #WSGI 服务器	生产环境部署 Flask 应用，处理并发请求
    "pydantic", #数据验证库	定义数据模型、请求/响应数据验证、类型检查
    "pydantic_settings", #配置管理	从环境变量、配置文件加载应用配置
    "cryptography", #加密库	数据加密解密、密码哈希、安全通信
    "python-docx", #Word 文档处理	创建、读取、修改 Word 文档（.docx）
    "captcha",#验证码生成	生成文字验证码、算术验证码
    "Pillow",#图像处理库	处理图片、生成验证码图片、图像缩放裁剪
    "pyjwt"  #JWT 库	生成和验证 JSON Web Token，用于用户认证
]

# 这里可以根据需要添加可选依赖
# 使用 `pip intall .[cpu]` 或 `pip install .[gpu]` 来安装相应的依赖
[project.optional-dependencies]

[project.scripts]
ddet-prod = "main:entry_point"
ddet-dev = "main:development_entry_point"
